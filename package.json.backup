{
  "name": "cash-property-analyzer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:property": "vitest run src/tests/property",
    "test:golden": "vitest run src/tests/golden",
    "test:integration": "vitest run src/tests/integration",
    "test:unit": "vitest run src/tests/unit",
    "test:all": "npm run test && npm run test:coverage",
    "audit": "powershell -File scripts/security-audit.ps1",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "clsx": "^2.0.0",
    "date-fns": "^4.0.0",
    "localforage": "^1.10.0",
    "lucide-react": "^0.562.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "fast-check": "^4.5.3",
    "jsdom": "^24.1.3",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
