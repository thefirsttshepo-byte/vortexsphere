{
  "name": "cash-property-analyzer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pwa:icons": "node scripts/generate-icons.js",
    "pwa:audit": "lighthouse http://localhost:3002 --view --output=json --output-path=./lighthouse-report.json",
    "deploy": "npm run build && echo 'Deploy dist/ folder to Netlify, Vercel, or GitHub Pages'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:property": "vitest run src/tests/property",
    "test:golden": "vitest run src/tests/golden",
    "test:integration": "vitest run src/tests/integration",
    "test:unit": "vitest run src/tests/unit",
    "test:all": "npm run test && npm run test:coverage && npm run test:property",
    "test:fast-check": "vitest run src/tests/property/fast-check.test.ts -- --numRuns 5000",
    "audit": "powershell -File scripts/security-audit.ps1",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "clsx": "^2.0.0",
    "date-fns": "^4.0.0",
    "decimal.js": "^10.6.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "localforage": "^1.10.0",
    "lucide-react": "^0.562.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/html2canvas": "^0.5.35",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fast-check": "^4.5.3",
    "globals": "^17.0.0",
    "jsdom": "^27.4.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.16"
  }
}
